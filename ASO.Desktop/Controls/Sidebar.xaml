<UserControl x:Class="ASO.Desktop.Controls.Sidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="220"
             Background="{StaticResource SidebarBrush}">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Logo / Marca -->
    <Border Grid.Row="0" Padding="20,24,20,20" BorderBrush="{StaticResource SidebarBorderBrush}" BorderThickness="0,0,0,1">
      <StackPanel>
        <TextBlock Text="Software ASO" FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource PrimaryBrush}" />
        <TextBlock Text="Gestión de Zafra" FontSize="11"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" />
      </StackPanel>
    </Border>

    <!-- Navegación (todas las secciones del plan) -->
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <StackPanel Margin="0,8,0,16">

        <RadioButton Style="{StaticResource NavItemStyle}" GroupName="MainNav" IsChecked="True"
                     Tag="Inicio" Checked="OnNavChecked">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                       VerticalAlignment="Center" Margin="0,0,10,0" />
            <TextBlock Text="Inicio" VerticalAlignment="Center" />
          </StackPanel>
        </RadioButton>

        <TextBlock Style="{StaticResource NavGroupHeaderStyle}" Text="Operación diaria" />

        <RadioButton Style="{StaticResource NavItemStyle}" GroupName="MainNav"
                     Tag="Operaciones" Checked="OnNavChecked">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE9F5;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                       VerticalAlignment="Center" Margin="0,0,10,0" />
            <TextBlock Text="Operaciones" VerticalAlignment="Center" />
          </StackPanel>
        </RadioButton>
        <RadioButton Style="{StaticResource NavItemStyle}" GroupName="MainNav"
                     Tag="Flota" Checked="OnNavChecked">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                       VerticalAlignment="Center" Margin="0,0,10,0" />
            <TextBlock Text="Flota y activos" VerticalAlignment="Center" />
          </StackPanel>
        </RadioButton>
        <RadioButton Style="{StaticResource NavItemStyle}" GroupName="MainNav"
                     Tag="Combustible" Checked="OnNavChecked">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                       VerticalAlignment="Center" Margin="0,0,10,0" />
            <TextBlock Text="Combustible" VerticalAlignment="Center" />
          </StackPanel>
        </RadioButton>

        <TextBlock Style="{StaticResource NavGroupHeaderStyle}" Text="Taller" />

        <RadioButton Style="{StaticResource NavItemStyle}" GroupName="MainNav"
                     Tag="Mantenimiento" Checked="OnNavChecked">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE90F;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                       VerticalAlignment="Center" Margin="0,0,10,0" />
            <TextBlock Text="Mantenimiento" VerticalAlignment="Center" />
          </StackPanel>
        </RadioButton>
        <RadioButton Style="{StaticResource NavItemStyle}" GroupName="MainNav"
                     Tag="Inventario" Checked="OnNavChecked">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                       VerticalAlignment="Center" Margin="0,0,10,0" />
            <TextBlock Text="Inventario" VerticalAlignment="Center" />
          </StackPanel>
        </RadioButton>

        <TextBlock Style="{StaticResource NavGroupHeaderStyle}" Text="Administración" />

        <RadioButton Style="{StaticResource NavItemStyle}" GroupName="MainNav"
                     Tag="Finanzas" Checked="OnNavChecked">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE8C7;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                       VerticalAlignment="Center" Margin="0,0,10,0" />
            <TextBlock Text="Finanzas" VerticalAlignment="Center" />
          </StackPanel>
        </RadioButton>
        <RadioButton Style="{StaticResource NavItemStyle}" GroupName="MainNav"
                     Tag="Nomina" Checked="OnNavChecked">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                       VerticalAlignment="Center" Margin="0,0,10,0" />
            <TextBlock Text="Nómina y destajo" VerticalAlignment="Center" />
          </StackPanel>
        </RadioButton>

        <TextBlock Style="{StaticResource NavGroupHeaderStyle}" Text="Sistema" />

        <RadioButton Style="{StaticResource NavItemStyle}" GroupName="MainNav"
                     Tag="Reportes" Checked="OnNavChecked">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                       VerticalAlignment="Center" Margin="0,0,10,0" />
            <TextBlock Text="Reportes" VerticalAlignment="Center" />
          </StackPanel>
        </RadioButton>
        <RadioButton Style="{StaticResource NavItemStyle}" GroupName="MainNav"
                     Tag="Maestros" Checked="OnNavChecked">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                       VerticalAlignment="Center" Margin="0,0,10,0" />
            <TextBlock Text="Maestros" VerticalAlignment="Center" />
          </StackPanel>
        </RadioButton>
        <RadioButton Style="{StaticResource NavItemStyle}" GroupName="MainNav"
                     Tag="Configuracion" Checked="OnNavChecked">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                       VerticalAlignment="Center" Margin="0,0,10,0" />
            <TextBlock Text="Configuración" VerticalAlignment="Center" />
          </StackPanel>
        </RadioButton>

      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
