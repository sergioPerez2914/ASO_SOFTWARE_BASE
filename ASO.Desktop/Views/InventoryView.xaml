<UserControl x:Class="ASO.Desktop.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:ASO.Desktop.Converters"
             mc:Ignorable="d"
             d:DesignHeight="640" d:DesignWidth="960">

  <UserControl.Resources>
    <conv:StockStatusToBrushConverter x:Key="StatusBrush" />

    <!-- Celda numérica alineada a la derecha -->
    <Style x:Key="NumCell" TargetType="TextBlock">
      <Setter Property="HorizontalAlignment" Value="Right" />
      <Setter Property="Margin" Value="0,0,10,0" />
    </Style>
  </UserControl.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Encabezado -->
    <StackPanel Grid.Row="0" Margin="0,0,0,16">
      <TextBlock Text="Inventario de repuestos" FontSize="20" FontWeight="Bold"
                 Foreground="{StaticResource TextPrimaryBrush}" />
      <TextBlock Text="Control de stock de repuestos críticos y consumibles de taller"
                 FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" />
    </StackPanel>

    <!-- Indicadores -->
    <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,16">
      <Border Style="{StaticResource CardStyle}" Margin="0,0,6,0">
        <StackPanel>
          <TextBlock Text="Total de artículos" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
          <TextBlock Text="{Binding TotalArticulos}" FontSize="26" FontWeight="Bold"
                     Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0" />
        </StackPanel>
      </Border>
      <Border Style="{StaticResource CardStyle}" Margin="6,0,6,0">
        <StackPanel>
          <TextBlock Text="Valor de inventario" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
          <TextBlock Text="{Binding ValorTotal, StringFormat=N0}" FontSize="26" FontWeight="Bold"
                     Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0" />
        </StackPanel>
      </Border>
      <Border Style="{StaticResource CardStyle}" Margin="6,0,6,0">
        <StackPanel>
          <TextBlock Text="Bajo mínimo" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
          <TextBlock Text="{Binding BajoMinimo}" FontSize="26" FontWeight="Bold"
                     Foreground="{StaticResource WarningBrush}" Margin="0,4,0,0" />
        </StackPanel>
      </Border>
      <Border Style="{StaticResource CardStyle}" Margin="6,0,0,0">
        <StackPanel>
          <TextBlock Text="Agotados" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
          <TextBlock Text="{Binding Agotados}" FontSize="26" FontWeight="Bold"
                     Foreground="{StaticResource DangerBrush}" Margin="0,4,0,0" />
        </StackPanel>
      </Border>
    </UniformGrid>

    <!-- Filtros -->
    <Grid Grid.Row="2" Margin="0,0,0,12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
        <TextBlock Text="Buscar" VerticalAlignment="Center" Margin="0,0,8,0"
                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
        <TextBox Width="280" Padding="6,4" VerticalContentAlignment="Center"
                 Text="{Binding Busqueda, UpdateSourceTrigger=PropertyChanged}" />
      </StackPanel>

      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
        <TextBlock Text="Categoría" VerticalAlignment="Center" Margin="0,0,8,0"
                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
        <ComboBox Width="200" Padding="6,4"
                  ItemsSource="{Binding Categorias}"
                  SelectedItem="{Binding CategoriaSeleccionada}" />
      </StackPanel>
    </Grid>

    <!-- Tabla -->
    <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="8">
      <DataGrid Style="{StaticResource DataGridStyle}" ItemsSource="{Binding ItemsView}">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Código" Binding="{Binding Codigo}" Width="90" />
          <DataGridTextColumn Header="Artículo" Binding="{Binding Nombre}" Width="*" />
          <DataGridTextColumn Header="Categoría" Binding="{Binding Categoria}" Width="170" />
          <DataGridTextColumn Header="Ubicación" Binding="{Binding Ubicacion}" Width="110" />
          <DataGridTextColumn Header="Stock" Binding="{Binding StockActual}" Width="70"
                              ElementStyle="{StaticResource NumCell}" />
          <DataGridTextColumn Header="Unidad" Binding="{Binding Unidad}" Width="70" />
          <DataGridTextColumn Header="Mínimo" Binding="{Binding StockMinimo}" Width="70"
                              ElementStyle="{StaticResource NumCell}" />
          <DataGridTextColumn Header="Costo unit." Binding="{Binding CostoUnitario, StringFormat=N2}" Width="95"
                              ElementStyle="{StaticResource NumCell}" />
          <DataGridTextColumn Header="Valor total" Binding="{Binding ValorTotal, StringFormat=N2}" Width="110"
                              ElementStyle="{StaticResource NumCell}" />
          <DataGridTemplateColumn Header="Estado" Width="120">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <Border Background="{Binding Estado, Converter={StaticResource StatusBrush}, ConverterParameter=bg}"
                        CornerRadius="10" Padding="10,3" HorizontalAlignment="Left" VerticalAlignment="Center">
                  <TextBlock Text="{Binding EstadoTexto}" FontSize="11" FontWeight="SemiBold"
                             Foreground="{Binding Estado, Converter={StaticResource StatusBrush}, ConverterParameter=fg}" />
                </Border>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
        </DataGrid.Columns>
      </DataGrid>
    </Border>
  </Grid>
</UserControl>
