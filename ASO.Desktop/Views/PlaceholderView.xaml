<UserControl x:Class="ASO.Desktop.Views.PlaceholderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="640" d:DesignWidth="960">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Encabezado (mismo patrón que los módulos reales) -->
    <StackPanel Grid.Row="0" Margin="0,0,0,16">
      <StackPanel Orientation="Horizontal">
        <TextBlock x:Name="TituloText" FontSize="20" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
        <Border x:Name="FaseBadge" Background="{StaticResource BackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="4" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
          <TextBlock x:Name="FaseText" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
        </Border>
      </StackPanel>
      <TextBlock x:Name="SubtituloText" FontSize="12"
                 Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" TextWrapping="Wrap" />
    </StackPanel>

    <!-- Estado de construcción -->
    <Border Grid.Row="1" Style="{StaticResource CardStyle}">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock x:Name="IconoText" FontFamily="Segoe MDL2 Assets" FontSize="40"
                   Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" />
        <TextBlock Text="Módulo en construcción" FontSize="16" FontWeight="SemiBold"
                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,12,0,0" />
        <TextBlock Text="Esta sección se conectará a datos reales cuando esté lista la capa de base de datos."
                   FontSize="12" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"
                   Margin="0,4,0,0" TextAlignment="Center" MaxWidth="380" TextWrapping="Wrap" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
